{
    "compilerOptions": {
        "target": "ES2020",
        "lib": [
            "ES2020",
            "DOM"
        ],
        "strict": true,
        "noEmit": true,
        "skipLibCheck": false,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noImplicitReturns": true,
        "noFallthroughCasesInSwitch": true,
        "exactOptionalPropertyTypes": true
    },
    "include": [
        "src/**/*.ts",
        "lib/**/*.ts"
    ]
}