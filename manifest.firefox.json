{
    "manifest_version": 3,
    "name": "Proxer Anime Skip",
    "version": "1.2",
    "description": "Automatically skip anime openings on proxer.me",
    "permissions": [
        "activeTab",
        "storage"
    ],
    "content_scripts": [
        {
            "matches": [
                "https://proxer.me/watch/*"
            ],
            "js": [
                "dist/content.js"
            ],
            "run_at": "document_end"
        },
        {
            "matches": [
                "https://stream.proxer.me/embed-*",
                "https://stream-service.proxer.me/embed-*"
            ],
            "js": [
                "dist/iframe-content.js"
            ],
            "run_at": "document_end",
            "all_frames": true
        }
    ],
    "action": {
        "default_popup": "popup.html",
        "default_title": "Proxer Skip Settings",
        "default_icon": "icon-128x128.png"
    },
    "icons": {
        "128": "icon-128x128.png"
    },
    "browser_specific_settings": {
        "gecko": {
            "id": "proxer-anime-skip@stschiff.dev",
            "strict_min_version": "140.0",
            "update_url": "https://extensions.stschiff.de/firefox/proxer-skip/addons.json",
            "data_collection_permissions": {
                "required": [
                    "websiteContent"
                ]
            }
        },
        "gecko_android": {
            "strict_min_version": "142.0"
        }
    }
}